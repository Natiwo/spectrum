{
	"name": "@natiwo/spectrum-cli",
	"version": "0.1.2",
	"description": "CLI for Spectrum semantic memory. The spm command.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"spm": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"ai",
		"memory",
		"cli",
		"semantic-search",
		"mcp"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Natiwo/spectrum",
		"directory": "packages/cli"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@natiwo/spectrum": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.5.0"
	}
}
