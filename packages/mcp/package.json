{
	"name": "@natiwo/spectrum-mcp",
	"version": "0.1.2",
	"description": "MCP server for Spectrum semantic memory. Connect Claude, Gemini, Codex to persistent memory.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"spectrum-mcp": "./dist/server.js"
	},
	"files": [
