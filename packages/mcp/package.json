		"README.md",
		"LICENSE"
	],
	"keywords": [
		"ai",
		"memory",
		"mcp",
		"claude",
		"gemini",
		"codex",
		"semantic-search"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Natiwo/spectrum",
		"directory": "packages/mcp"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"@natiwo/spectrum": "workspace:*",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0"
	}
}
