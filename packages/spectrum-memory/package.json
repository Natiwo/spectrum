{
	"name": "@natiwo/spectrum-memory",
	"version": "0.2.1",
	"description": "Persistent semantic memory for AI agents. Local-first, SQLite, embeddings, MCP-ready.",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"spm": "dist/cli.js",
		"spectrum-mcp": "dist/server.js"
	},
	"files": ["dist", "README.md", "LICENSE"],
	"sideEffects": false,
	"keywords": [
		"ai",
		"memory",
		"semantic-search",
		"embeddings",
		"mcp",
		"sqlite",
		"llm",
		"context",
		"claude",
		"gemini",
		"codex",
		"neurodiversity",
		"spectrum"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Natiwo/spectrum.git",
		"directory": "packages/spectrum-memory"
	},
	"publishConfig": { "access": "public" },
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"better-sqlite3": "^11.0.0",
		"zod": "^3.24.0"
	},
	"optionalDependencies": {
		"@huggingface/transformers": "^3.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.0",
		"@types/node": "^25.5.0"
	}
}
